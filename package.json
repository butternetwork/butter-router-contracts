{
  "name": "@butternetwork/router",
  "version": "2.0.0",
  "description": "Butter omni-chain aggregate swap contracts based on MAP Protocol",
  "main": "index.js",
  "files": [
    "artifacts/contracts/**/*.sol/*.json",
    "!artifacts/contracts/**/*.sol/*.dbg.json",
    "!artifacts/contracts/mock/*.sol/*.json",
    "deployments/*/*.json",
    "contracts",
    "!contracts/mock/*.sol"
  ],
  "scripts": {
    "format:sol": "prettier --print-width 120 --tab-width 4 --write ./contracts",
    "format": "prettier --print-width 120 --write ./scripts ./tasks ./test ./utils ./configs",
    "flatten:all": "npx hardhat flatten:all",
    "flatten:v31": "npx hardhat flatten:contract --contract ButterRouterV31"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/butternetwork/butter-router-contracts.git"
  },
  "author": "Butter Network",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/butternetwork/butter-router-contracts/issues"
  },
  "homepage": "https://butternetwork.io",
  "devDependencies": {
    "@matterlabs/hardhat-zksync": "^1.6.2",
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-ignition": "^0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@nomicfoundation/ignition-core": "^0.15.15",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@xplorfin/hardhat-solc-excludes": "^0.1.1",
    "chai": "^4.5.0",
    "dotenv": "^16.0.3",
    "ethers": "^6.16.0",
    "hardhat": "^2.22.0",
    "hardhat-deploy": "^0.12.0",
    "hardhat-gas-reporter": "^1.0.10",
    "hardhat-preprocessor": "^0.1.5",
    "prettier": "^2.8.8",
    "prettier-plugin-solidity": "^1.1.0",
    "solidity-coverage": "^0.8.17",
    "tronweb": "^5.3.0",
    "ts-node": "^10.9.1",
    "typechain": "^8.3.2",
    "typescript": "^4.9.5"
  },
  "dependencies": {
    "@butternetwork/bridge": "3.0.0",
    "@mapprotocol/common-contracts": "^0.4.0",
    "@openzeppelin/contracts": "4.9.6"
  },
  "overrides": {
    "axios": "1.15.0"
  },
  "keywords": [
    "butternetwork",
    "butter",
    "swap",
    "mapprotocol",
    "mapo",
    "omnichain",
    "cross-chain",
    "solidity"
  ]
}
